# ==================== 应用基础配置 ====================
APP_NAME=Windify
APP_VERSION=0.1.0
# 生产环境设置为 False
DEBUG_MODE=False

# ==================== 服务器配置 ====================
# 容器内监听所有接口
HOST=0.0.0.0
PORT=8000
# 生产环境设置为 False
RELOAD=False

# ==================== 文件配置 ====================
STATIC_DIR=static

# ==================== JWT ====================
# 务必替换为随机长字符串，不要使用默认值
SECRET_KEY=change-me-to-a-random-secret

# ==================== PostgreSQL ====================
# PG/Redis 跑在宿主机上时，容器内用 host.docker.internal 访问
PG_HOST=host.docker.internal
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_pg_password
PG_DATABASE=daisywind

# ==================== Redis ====================
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ==================== LLM（可选）====================
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
